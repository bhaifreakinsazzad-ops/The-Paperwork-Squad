# ============================================================
# THE PAPERWORK SQUAD — ENVIRONMENT VARIABLES
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to Git — it's in .gitignore
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Stripe ───────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
# Use pk_test_ during dev, pk_live_ for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── App Config ───────────────────────────────────────────────
VITE_APP_URL=https://thepaperworksquad.com
VITE_SUPPORT_EMAIL=support@thepaperworksquad.com
